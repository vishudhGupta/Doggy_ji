        "label": "t:sections.general.settings.remove_bottom_spacing.label"
      }
    ],
    "blocks": [
      {
        "type": "blurb_icon",
        "name": "t:sections.counter-showcase.blocks.counter.name",
        "settings": [
          {
            "type": "select",
            "id": "show_icon",
            "options": [
