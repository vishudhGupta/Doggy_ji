<div id="usp-section-{{ section.id }}" class="usp-section top-spacing-{{ section.settings.top_spacing }}">
	<div class="{% if section.settings.width != 'default' %}{{ section.settings.width }}{% else %}{{ settings.page_width_main }}{% endif %}">
		<div class="usp-section__inner">
			{% for block in section.blocks %}
				<div class="usp-item" {{ block.shopify_attributes }}>
					{% if block.settings.icon != blank %}
						<div class="usp-item__icon-wrap">
							{{
								block.settings.icon
								| image_url: width: 80
								| image_tag:
									loading: 'lazy',
									widths: '40,60,80',
									sizes: '(max-width: 749px) 30px, 40px',
									class: 'usp-item__icon',
									alt: block.settings.heading
							}}
						</div>
					{% endif %}

					{% if block.settings.heading != blank %}
						<h3 class="usp-item__heading">{{ block.settings.heading }}</h3>
					{% endif %}

					{% if block.settings.description != blank %}
						<p class="usp-item__description">{{ block.settings.description }}</p>
					{% endif %}
				</div>
			{% endfor %}
		</div>
	</div>
</div>

<style>
	#usp-section-{{ section.id }} {
		background: #FEBB4A;
	}

	#usp-section-{{ section.id }} .usp-section__inner {
		border-radius: {{ section.settings.border_radius }}px;
		padding: 14px 10px;
		display: flex;
		gap: 4px;
		align-items: stretch;
		justify-content: space-between;
	}

	#usp-section-{{ section.id }} .usp-item {
		flex: 1 1 25%;
		min-width: 0;
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	#usp-section-{{ section.id }} .usp-item__icon-wrap {
		height: 28px;
		display: flex;
		align-items: center;
		justify-content: center;
		margin-bottom: 4px;
	}

	#usp-section-{{ section.id }} .usp-item__icon {
		width: 24px;
		height: 24px;
		object-fit: contain;
	}

	#usp-section-{{ section.id }} .usp-item__heading {
		margin: 0;
		color: {{ section.settings.heading_color }};
		font-size: 18px;
		line-height: 1.15;
		font-weight: 700;
		letter-spacing: 0;
	}

	#usp-section-{{ section.id }} .usp-item__description {
		margin: 2px 0 0;
		color: {{ section.settings.text_color }};
		font-size: 14px;
		line-height: 1.2;
		font-weight: 400;
	}

	@media screen and (max-width: 749px) {
		#usp-section-{{ section.id }} .usp-section__inner {
			padding: 10px 4px;
			gap: 2px;
			border-radius: {{ section.settings.border_radius_mobile }}px;
			align-items: flex-start;
		}

		#usp-section-{{ section.id }} .usp-item {
			overflow: hidden;
			padding: 0 2px;
			justify-content: flex-start;
		}

		#usp-section-{{ section.id }} .usp-item__icon-wrap {
			height: 20px;
			margin-bottom: 3px;
		}

		#usp-section-{{ section.id }} .usp-item__icon {
			width: 16px;
			height: 16px;
		}

		#usp-section-{{ section.id }} .usp-item__heading {
			font-size: 9px;
			line-height: 1.1;
			min-height: calc(9px * 1.1);
			white-space: normal;
			overflow-wrap: anywhere;
			max-width: 100%;
			display: -webkit-box;
			-webkit-line-clamp: 1;
			-webkit-box-orient: vertical;
			overflow: hidden;
		}

		#usp-section-{{ section.id }} .usp-item__description {
			display: none;
		}
	}
</style>

{% schema %}
{
	"name": "USP",
	"tag": "section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "top_spacing",
			"label": "Top spacing",
			"default": "normal",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "small", "label": "Small" },
				{ "value": "medium", "label": "Medium" },
				{ "value": "normal", "label": "Normal" }
			]
		},
		{
			"type": "select",
			"id": "width",
			"label": "Content width",
			"default": "default",
			"options": [
				{ "value": "default", "label": "Theme default" },
				{ "value": "page-width", "label": "Boxed" },
				{ "value": "page-wide", "label": "Wide" }
			]
		},
		{
			"type": "range",
			"id": "border_radius",
			"label": "Desktop border radius",
			"min": 0,
			"max": 30,
			"step": 1,
			"default": 0
		},
		{
			"type": "range",
			"id": "border_radius_mobile",
			"label": "Mobile border radius",
			"min": 0,
			"max": 30,
			"step": 1,
			"default": 0
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "background_color",
			"label": "Background",
			"default": "#f4d215"
		},
		{
			"type": "color",
			"id": "heading_color",
			"label": "Heading",
			"default": "#0f0f0f"
		},
		{
			"type": "color",
			"id": "text_color",
			"label": "Description",
			"default": "#333333"
		}
	],
	"blocks": [
		{
			"type": "item",
			"name": "USP item",
			"limit": 4,
			"settings": [
				{
					"type": "image_picker",
					"id": "icon",
					"label": "Icon (PNG)"
				},
				{
					"type": "text",
					"id": "heading",
					"label": "Heading",
					"default": "Ask Expert"
				},
				{
					"type": "text",
					"id": "description",
					"label": "Description",
					"default": "Get the help of Expert to find best"
				}
			]
		}
	],
	"max_blocks": 4,
	"presets": [
		{
			"name": "USP",
			"blocks": [
				{
					"type": "item",
					"settings": {
						"heading": "Ask Expert",
						"description": "Get the help of Expert to find best"
					}
				},
				{
					"type": "item",
					"settings": {
						"heading": "Chat With Us",
						"description": "We offer 24-hour chat support"
					}
				},
				{
					"type": "item",
					"settings": {
						"heading": "Fast Delivery",
						"description": "Get Fast & Free Delivery"
					}
				},
				{
					"type": "item",
					"settings": {
						"heading": "Best Packaging",
						"description": "Best Quality Packaging"
					}
				}
			]
		}
	]
}
{% endschema %}
