{%- liquid
	assign font_stack = "inherit"
	case section.settings.font_family
		when "modern"
			assign font_stack = "'Poppins', sans-serif"
		when "geometric"
			assign font_stack = "'Montserrat', sans-serif"
		when "clean"
			assign font_stack = "'DM Sans', sans-serif"
		when "rounded"
			assign font_stack = "'Nunito Sans', sans-serif"
	endcase

	assign has_social = false
	assign has_contact = false
	assign has_menu_columns = false
	assign has_popular_links = false
	assign has_popular_content = false

	for block in section.blocks
		if block.type == 'social_link'
			assign has_social = true
		elsif block.type == 'contact_item'
			assign has_contact = true
		elsif block.type == 'menu_column' or block.type == 'text_column'
			assign has_menu_columns = true
		elsif block.type == 'popular_search_link'
			assign has_popular_links = true
		endif
	endfor

	if has_popular_links or section.settings.popular_searches_text != blank
		assign has_popular_content = true
	endif
-%}

<style>
	.custom-footer {
		--cf-bg: {{ section.settings.bg_color }};
		--cf-text: {{ section.settings.text_color }};
		--cf-muted: {{ section.settings.muted_color }};
		--cf-social-bg: {{ section.settings.social_bg_color }};
		--cf-social-text: {{ section.settings.social_text_color }};
		--cf-divider: {{ section.settings.divider_color }};
		--cf-max-width: {{ section.settings.max_width }}px;
		--cf-title-size: {{ section.settings.title_size }}px;
		--cf-hash-size: {{ section.settings.hash_size }}px;
		--cf-body-size: {{ section.settings.body_size }}px;
		--cf-menu-size: {{ section.settings.menu_size }}px;
		--cf-popular-size: {{ section.settings.popular_size }}px;
		--cf-social-size: {{ section.settings.social_size }}px;
		--cf-padding-top: {{ section.settings.padding_top }}px;
		--cf-padding-bottom: {{ section.settings.padding_bottom }}px;
		--cf-social-radius: {{ section.settings.social_radius }}px;
		background: var(--cf-bg);
		color: var(--cf-text);
		padding: var(--cf-padding-top) 0 var(--cf-padding-bottom);
		font-family: {{ font_stack }};
	}

	.custom-footer__container {
		width: min(var(--cf-max-width), calc(100% - 40px));
		margin: 0 auto;
	}

	.custom-footer__top {
		text-align: center;
	}

	.custom-footer__logo-wrap {
		width: {{ section.settings.logo_width }}px;
		max-width: 100%;
		margin: 0 auto;
	}

	.custom-footer__logo {
		width: 100%;
		height: auto;
		display: block;
		object-fit: contain;
	}

	.custom-footer__brand,
	.custom-footer__line,
	.custom-footer__title,
	.custom-footer__hash,
	.custom-footer__about,
	.custom-footer__heading,
	.custom-footer__searches-title,
	.custom-footer__searches-text,
	.custom-footer__list li,
	.custom-footer__text-column,
	.custom-footer__contact-item {
		margin: 0;
	}

	.custom-footer__brand {
		margin-top: 6px;
		line-height: 1.1;
		font-size: calc(var(--cf-title-size) - 8px);
		letter-spacing: 0.02em;
		font-weight: 700;
	}

	.custom-footer__line {
		display: block;
	}

	.custom-footer__title {
		margin-top: 4px;
		font-size: var(--cf-title-size);
		line-height: 1.15;
		font-weight: 600;
	}

	.custom-footer__hash {
		margin-top: 2px;
		font-size: 30px;
		line-height: 1.1;
		font-weight: 700;
		letter-spacing: 0.01em;
	}

	.custom-footer__social {
		margin-top: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		flex-wrap: wrap;
	}

	.custom-footer__social-link {
		background: var(--cf-social-bg);
		color: var(--cf-social-text);
		min-width: 178px;
		border-radius: var(--cf-social-radius);
		padding: 9px 18px;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 7px;
		text-decoration: none;
		font-weight: 600;
		font-size: var(--cf-social-size);
		line-height: 1;
		transition: transform 0.18s ease, opacity 0.18s ease;
	}

	.custom-footer__social-link:hover {
		opacity: 0.92;
		transform: translateY(-1px);
	}

	.custom-footer__social-link svg {
		width: 14px;
		height: 14px;
		fill: currentColor;
		flex-shrink: 0;
	}

	.custom-footer__about {
		margin: 20px auto 0;
		max-width: 920px;
		text-align: center;
		font-size: var(--cf-body-size);
		line-height: {{ section.settings.about_line_height }};
	}

	.custom-footer__links-grid {
		margin-top: 24px;
		display: grid;
		grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
		gap: 18px;
	}

	.custom-footer__heading {
		margin-bottom: 8px;
		font-size: calc(var(--cf-menu-size) + 1px);
		line-height: 1.25;
		font-weight: 600;
	}

	.custom-footer__list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.custom-footer__list li,
	.custom-footer__text-column,
	.custom-footer__contact-item {
		font-size: var(--cf-menu-size);
		line-height: 1.4;
		margin-bottom: 7px;
	}

	.custom-footer__list li:last-child,
	.custom-footer__contact-item:last-child {
		margin-bottom: 0;
	}

	.custom-footer__list a,
	.custom-footer__contact-item a {
		color: inherit;
		text-decoration: none;
	}

	.custom-footer__list a:hover,
	.custom-footer__contact-item a:hover {
		text-decoration: underline;
	}

	.custom-footer__text-column,
	.custom-footer__text-column p {
		color: var(--cf-muted);
	}

	.custom-footer__contact-item {
		display: flex;
		align-items: flex-start;
		gap: 7px;
	}

	.custom-footer__contact-item svg {
		width: 12px;
		height: 12px;
		margin-top: 4px;
		fill: currentColor;
		flex-shrink: 0;
	}

	.custom-footer__searches {
		margin-top: 26px;
	}

	.custom-footer__searches-title {
		font-size: calc(var(--cf-popular-size) + 2px);
		line-height: 1.2;
		font-weight: 700;
		text-transform: uppercase;
		margin-bottom: 8px;
	}

	.custom-footer__searches-text {
		font-size: var(--cf-popular-size);
		line-height: 1.45;
		color: var(--cf-muted);
	}

	.custom-footer__search-link {
		color: inherit;
		text-decoration: none;
	}

	.custom-footer__search-link:hover {
		text-decoration: underline;
	}

	.custom-footer__search-separator {
		display: inline-block;
		padding: 0 0px;
	}

	.custom-footer__divider {
		margin: 14px 0 0;
		border: 0;
		border-top: 1px solid var(--cf-divider);
	}

	@media (max-width: 990px) {
		.custom-footer__container {
			width: calc(100% - 28px);
		}

		.custom-footer__links-grid {
			grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
		}

		.custom-footer__social-link {
			min-width: 150px;
		}
	}

	@media (max-width: 576px) {
		.custom-footer__container {
			width: calc(100% - 20px);
		}

		.custom-footer__links-grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			margin-top: 20px;
			gap: 14px;
		}

		.custom-footer__menu-column {
			min-width: 0;
		}

		.custom-footer__social {
			gap: 6px;
			flex-wrap: nowrap;
			overflow-x: auto;
			padding-bottom: 2px;
		}

		.custom-footer__social-link {
			min-width: 0;
			width: auto;
			flex: 1 1 0;
			padding-left: 12px;
			padding-right: 12px;
			font-size: calc(var(--cf-social-size) - 1px);
		}

		.custom-footer__about {
			margin-top: 16px;
		}
	}
</style>

<footer class="custom-footer" role="contentinfo">
	<div class="custom-footer__container">
		<div class="custom-footer__top">
			{% if section.settings.show_logo %}
				<div class="custom-footer__logo-wrap">
					{% if section.settings.logo_image != blank %}
						{{ section.settings.logo_image | image_url: width: 500 | image_tag: class: 'custom-footer__logo', loading: 'lazy', alt: shop.name }}
					{% elsif settings.logo != blank %}
						{{ settings.logo | image_url: width: 500 | image_tag: class: 'custom-footer__logo', loading: 'lazy', alt: shop.name }}
					{% endif %}
				</div>
			{% endif %}

			{% if section.settings.brand_line_1 != blank %}
				<p class="custom-footer__brand">
					{% assign lines = section.settings.brand_line_1 | newline_to_br | split: '<br />' %}
					{% for line in lines %}
						{% if line != blank %}
							<span class="custom-footer__line">{{ line }}</span>
						{% endif %}
					{% endfor %}
				</p>
			{% endif %}

			{% if section.settings.brand_title != blank %}
				<p class="custom-footer__title">{{ section.settings.brand_title }}</p>
			{% endif %}

			{% if section.settings.brand_hash != blank %}
				<p class="custom-footer__hash">{{ section.settings.brand_hash }}</p>
			{% endif %}

			{% if has_social %}
				<div class="custom-footer__social" aria-label="Social links">
					{% for block in section.blocks %}
						{% if block.type == 'social_link' and block.settings.url != blank and block.settings.label != blank %}
							<a
								class="custom-footer__social-link"
								href="{{ block.settings.url }}"
								{% if section.settings.open_social_new_tab %}
									target="_blank"
									rel="noopener noreferrer"
								{% endif %}
								{{ block.shopify_attributes }}
							>
								{% if block.settings.icon != 'none' %}
									{% case block.settings.icon %}
										{% when 'instagram' %}
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.2c3.2 0 3.6 0 4.8.1 1 .1 1.6.2 2 .4.5.2.9.4 1.3.8.4.4.6.8.8 1.3.2.4.3 1 .4 2 .1 1.2.1 1.6.1 4.8s0 3.6-.1 4.8c-.1 1-.2 1.6-.4 2-.2.5-.4.9-.8 1.3-.4.4-.8.6-1.3.8-.4.2-1 .3-2 .4-1.2.1-1.6.1-4.8.1s-3.6 0-4.8-.1c-1-.1-1.6-.2-2-.4-.5-.2-.9-.4-1.3-.8-.4-.4-.6-.8-.8-1.3-.2-.4-.3-1-.4-2-.1-1.2-.1-1.6-.1-4.8s0-3.6.1-4.8c.1-1 .2-1.6.4-2 .2-.5.4-.9.8-1.3.4-.4.8-.6 1.3-.8.4-.2 1-.3 2-.4 1.2-.1 1.6-.1 4.8-.1Zm0 1.9c-3.1 0-3.5 0-4.7.1-.9 0-1.4.2-1.8.3-.4.2-.7.3-1 .6-.3.3-.5.6-.6 1-.2.4-.3.9-.3 1.8-.1 1.2-.1 1.6-.1 4.7s0 3.5.1 4.7c0 .9.2 1.4.3 1.8.2.4.3.7.6 1 .3.3.6.5 1 .6.4.2.9.3 1.8.3 1.2.1 1.6.1 4.7.1s3.5 0 4.7-.1c.9 0 1.4-.2 1.8-.3.4-.2.7-.3 1-.6.3-.3.5-.6.6-1 .2-.4.3-.9.3-1.8.1-1.2.1-1.6.1-4.7s0-3.5-.1-4.7c0-.9-.2-1.4-.3-1.8-.2-.4-.3-.7-.6-1-.3-.3-.6-.5-1-.6-.4-.2-.9-.3-1.8-.3-1.2-.1-1.6-.1-4.7-.1Zm0 3.3a4.7 4.7 0 1 1 0 9.4 4.7 4.7 0 0 1 0-9.4Zm0 1.9a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6Zm6-3.5a1.1 1.1 0 1 1 0 2.2 1.1 1.1 0 0 1 0-2.2Z"/></svg>
										{% when 'facebook' %}
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M13.5 8.2V6.8c0-.6.4-1 1-1h1.5V3.1h-2.1c-2.4 0-3.9 1.4-3.9 3.9v1.2H8v2.8h2v6h3.1v-6h2.4l.4-2.8h-2.8Z"/></svg>
										{% when 'youtube' %}
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M22 8.2a3 3 0 0 0-2.1-2.1C18 5.5 12 5.5 12 5.5s-6 0-7.9.6A3 3 0 0 0 2 8.2 31 31 0 0 0 1.5 12c0 1.3.2 2.6.5 3.8a3 3 0 0 0 2.1 2.1c1.9.6 7.9.6 7.9.6s6 0 7.9-.6a3 3 0 0 0 2.1-2.1c.3-1.2.5-2.5.5-3.8s-.2-2.6-.5-3.8ZM10 15.3V8.7l5.7 3.3L10 15.3Z"/></svg>
										{% when 'x' %}
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18.9 2h3.3l-7.2 8.2L23.5 22h-6.6l-5.2-6.9L5.7 22H2.4l7.7-8.8L.5 2h6.8l4.7 6.3L18.9 2Zm-1.2 18h1.8L6.3 3.9H4.4L17.7 20Z"/></svg>
										{% when 'linkedin' %}
											<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4.5 3.5a2 2 0 1 1 0 4 2 2 0 0 1 0-4ZM3 8.8h3v12H3v-12Zm7.2 0h2.9v1.6h.1c.4-.8 1.4-1.8 3-1.8 3.2 0 3.8 2.1 3.8 4.9v7.3h-3v-6.5c0-1.6 0-3.5-2.1-3.5s-2.4 1.7-2.4 3.4v6.6h-3v-12Z"/></svg>
									{% endcase %}
								{% endif %}
								<span>{{ block.settings.label }}</span>
							</a>
						{% endif %}
					{% endfor %}
				</div>
			{% endif %}
		</div>

		{% if section.settings.about_text != blank %}
			<div class="custom-footer__about">{{ section.settings.about_text }}</div>
		{% endif %}

		{% if has_menu_columns or has_contact %}
			<div class="custom-footer__links-grid">
				{% for block in section.blocks %}
					{% if block.type == 'menu_column' %}
						<div class="custom-footer__menu-column" {{ block.shopify_attributes }}>
							{% if block.settings.heading != blank %}
								<p class="custom-footer__heading">{{ block.settings.heading }}</p>
							{% endif %}
							{% if block.settings.menu != blank %}
								<ul class="custom-footer__list">
									{% for link in block.settings.menu.links %}
										<li><a href="{{ link.url }}">{{ link.title }}</a></li>
									{% endfor %}
								</ul>
							{% endif %}
						</div>
					{% elsif block.type == 'text_column' %}
						<div class="custom-footer__menu-column" {{ block.shopify_attributes }}>
							{% if block.settings.heading != blank %}
								<p class="custom-footer__heading">{{ block.settings.heading }}</p>
							{% endif %}
							{% if block.settings.text != blank %}
								<div class="custom-footer__text-column">{{ block.settings.text }}</div>
							{% endif %}
						</div>
					{% endif %}
				{% endfor %}

				{% if has_contact %}
					<div class="custom-footer__contact-column">
						{% if section.settings.contact_heading != blank %}
							<p class="custom-footer__heading">{{ section.settings.contact_heading }}</p>
						{% endif %}
						{% for block in section.blocks %}
							{% if block.type == 'contact_item' and block.settings.text != blank %}
								<p class="custom-footer__contact-item" {{ block.shopify_attributes }}>
									{% if block.settings.icon != 'none' %}
										{% case block.settings.icon %}
											{% when 'location' %}
												<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.1c3.7 0 6.7 3 6.7 6.7 0 4.7-6.7 13-6.7 13S5.3 13.5 5.3 8.8c0-3.7 3-6.7 6.7-6.7Zm0 2.8a3.9 3.9 0 1 0 0 7.8 3.9 3.9 0 0 0 0-7.8Z"/></svg>
											{% when 'phone' %}
												<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6.6 10.8a15.8 15.8 0 0 0 6.6 6.6l2.2-2.2c.3-.3.8-.4 1.2-.3 1.3.4 2.6.6 4 .6.6 0 1 .5 1 1v3.5c0 .6-.4 1-1 1C11.6 21 3 12.4 3 1.9c0-.6.5-1 1-1h3.5c.6 0 1 .4 1 1 0 1.4.2 2.7.6 4 .1.4 0 .9-.3 1.2l-2.2 2.2Z"/></svg>
											{% when 'mail' %}
												<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 5h18a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1Zm0 2v.2l9 5.8 9-5.8V7H3Zm18 10V9.4l-8.5 5.5a1 1 0 0 1-1 0L3 9.4V17h18Z"/></svg>
										{% endcase %}
									{% endif %}

									{% if block.settings.link != blank %}
										<a href="{{ block.settings.link }}">{{ block.settings.text }}</a>
									{% else %}
										<span>{{ block.settings.text }}</span>
									{% endif %}
								</p>
							{% endif %}
						{% endfor %}
					</div>
				{% endif %}
			</div>
		{% endif %}

		{% if section.settings.show_popular_searches and has_popular_content %}
			<div class="custom-footer__searches">
				{% if section.settings.popular_searches_title != blank %}
					<p class="custom-footer__searches-title">{{ section.settings.popular_searches_title }}</p>
				{% endif %}
				<p class="custom-footer__searches-text">
					{% if has_popular_links %}
						{% assign rendered_popular_count = 0 %}
						{% for block in section.blocks %}
							{% if block.type == 'popular_search_link' and block.settings.label != blank and block.settings.url != blank %}
								{% if rendered_popular_count > 0 %}
									<span class="custom-footer__search-separator">{{ section.settings.popular_links_separator }}</span>
								{% endif %}
								<a
									class="custom-footer__search-link"
									href="{{ block.settings.url }}"
									{% if section.settings.open_popular_links_new_tab %}
										target="_blank"
										rel="noopener noreferrer"
									{% endif %}
									{{ block.shopify_attributes }}
								>
									{{ block.settings.label }}
								</a>
								{% assign rendered_popular_count = rendered_popular_count | plus: 1 %}
							{% endif %}
						{% endfor %}
					{% else %}
						{{ section.settings.popular_searches_text }}
					{% endif %}
				</p>
			</div>
		{% endif %}

		{% if section.settings.show_divider %}
			<hr class="custom-footer__divider">
		{% endif %}
	</div>
</footer>

{% schema %}
{
	"name": "Custom Footer",
	"settings": [
		{
			"type": "header",
			"content": "Brand Content"
		},
		{
			"type": "checkbox",
			"id": "show_logo",
			"label": "Show logo",
			"default": true
		},
		{
			"type": "image_picker",
			"id": "logo_image",
			"label": "Footer logo image"
		},
		{
			"type": "range",
			"id": "logo_width",
			"label": "Logo width",
			"min": 60,
			"max": 260,
			"step": 2,
			"unit": "px",
			"default": 120
		},
		{
			"type": "textarea",
			"id": "brand_line_1",
			"label": "Brand top text",
			"default": "DOGGY\nJI"
		},
		{
			"type": "text",
			"id": "brand_title",
			"label": "Main title",
			"default": "Good for Dogs"
		},
		{
			"type": "text",
			"id": "brand_hash",
			"label": "Hashtag text",
			"default": "#DOGGYJI"
		},
		{
			"type": "richtext",
			"id": "about_text",
			"label": "About text",
			"default": "<p>Doggy Ji biscuits are crafted with love and care. We use only the finest ingredients to ensure the highest quality and flavor.</p>"
		},
		{
			"type": "text",
			"id": "contact_heading",
			"label": "Contact column heading",
			"default": "Contact"
		},
		{
			"type": "header",
			"content": "Popular Searches"
		},
		{
			"type": "checkbox",
			"id": "show_popular_searches",
			"label": "Show popular searches",
			"default": true
		},
		{
			"type": "text",
			"id": "popular_searches_title",
			"label": "Popular searches title",
			"default": "Popular Searches:"
		},
		{
			"type": "textarea",
			"id": "popular_searches_text",
			"label": "Popular searches content",
			"default": "Doggy Ji Ragi Shots | Doggy Ji Biscuits (Chicken Extracts) - 96 Packets | Doggy Ji V-Bite (Vegan Biscuits) - 48 Packets | Doggy Ji Mini Combo"
		},
		{
			"type": "text",
			"id": "popular_links_separator",
			"label": "Popular link separator",
			"default": "|"
		},
		{
			"type": "checkbox",
			"id": "open_popular_links_new_tab",
			"label": "Open popular links in new tab",
			"default": false
		},
		{
			"type": "header",
			"content": "Style"
		},
		{
			"type": "select",
			"id": "font_family",
			"label": "Font family",
			"options": [
				{
					"value": "inherit",
					"label": "Theme default"
				},
				{
					"value": "modern",
					"label": "Poppins"
				},
				{
					"value": "geometric",
					"label": "Montserrat"
				},
				{
					"value": "clean",
					"label": "DM Sans"
				},
				{
					"value": "rounded",
					"label": "Nunito Sans"
