<style>
  .sec-2-abo {
    --abo-bg: {{ section.settings.background_color }};
    --abo-text: {{ section.settings.text_color }};
    --abo-muted: {{ section.settings.muted_color }};
    --abo-accent: {{ section.settings.accent_color }};
    --abo-max-width: {{ section.settings.max_width }}px;
    --abo-title-size: {{ section.settings.title_size }}px;
    --abo-subtitle-size: {{ section.settings.subtitle_size }}px;
    --abo-body-size: {{ section.settings.body_size }}px;
    background: var(--abo-bg);
    color: var(--abo-text);
    position: relative;
    overflow: hidden;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }

  .sec-2-abo__container {
    width: min(var(--abo-max-width), calc(100% - 32px));
    margin: 0 auto;
    position: relative;
  }

  .sec-2-abo__hero {
    position: relative;
    min-height: {{ section.settings.hero_min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .sec-2-abo__bg-image {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-repeat: no-repeat;
    background-position: center top;
    background-size: cover;
    opacity: {{ section.settings.background_image_opacity | divided_by: 100.0 }};
  }

  .sec-2-abo__side-image {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: min({{ section.settings.side_image_width }}px, 22vw);
    max-width: 100%;
    border-radius: {{ section.settings.side_image_radius }}px;
    overflow: hidden;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.08);
  }

  .sec-2-abo__side-image img {
    display: block;
    width: 100%;
    height: auto;
  }

  .sec-2-abo__side-image--left {
    left: 0;
  }

  .sec-2-abo__side-image--right {
    right: 0;
  }

  .sec-2-abo__content {
    position: relative;
    z-index: 2;
    max-width: {{ section.settings.content_max_width }}px;
    margin: 0 auto;
    padding: {{ section.settings.content_padding_top }}px 0 {{ section.settings.content_padding_bottom }}px;
  }

  .sec-2-abo__eyebrow {
    margin: 0 0 12px;
    font-size: {{ section.settings.eyebrow_size }}px;
    line-height: 1.15;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--abo-text);
  }

  .sec-2-abo__title {
    margin: 0;
    font-size: var(--abo-title-size);
    line-height: 0.92;
    font-weight: 900;
    letter-spacing: -0.05em;
    text-transform: uppercase;
  }

  .sec-2-abo__title-accent {
    color: var(--abo-accent);
  }

  .sec-2-abo__body {
    margin: 24px auto 0;
    max-width: {{ section.settings.body_max_width }}px;
    font-size: var(--abo-body-size);
    line-height: {{ section.settings.body_line_height }};
    color: var(--abo-muted);
  }

  .sec-2-abo__body strong {
    color: var(--abo-text);
    font-weight: 800;
  }

  @media (max-width: 990px) {
    .sec-2-abo__container {
      width: calc(100% - 24px);
    }

    .sec-2-abo__side-image {
      width: min({{ section.settings.side_image_width_tablet }}px, 20vw);
    }

    .sec-2-abo__title {
      font-size: calc(var(--abo-title-size) * 0.86);
    }
  }

  @media (max-width: 576px) {
    .sec-2-abo {
      padding: 28px 0 42px;
    }

    .sec-2-abo__container {
      width: calc(100% - 18px);
    }

    .sec-2-abo__hero {
      min-height: auto;
      padding-top: 14px;
    }

    .sec-2-abo__side-image {
      display: none;
    }

    .sec-2-abo__content {
      padding: 10px 0 0;
    }

    .sec-2-abo__eyebrow {
      margin-bottom: 8px;
      font-size: calc(var(--abo-subtitle-size) * 0.72);
    }

    .sec-2-abo__title {
      font-size: calc(var(--abo-title-size) * 0.54);
      line-height: 0.98;
      letter-spacing: -0.04em;
    }

    .sec-2-abo__body {
      margin-top: 18px;
      font-size: calc(var(--abo-body-size) - 1px);
    }
  }
</style>

<section class="sec-2-abo" aria-label="About section">
  <div class="sec-2-abo__container">
    <div class="sec-2-abo__hero">
      {% if section.settings.background_image != blank %}
        <div class="sec-2-abo__bg-image" style="background-image: url('{{ section.settings.background_image | image_url: width: 2400 }}');" aria-hidden="true"></div>
      {% endif %}

      {% if section.settings.left_image != blank %}
        <div class="sec-2-abo__side-image sec-2-abo__side-image--left" aria-hidden="true">
          {{ section.settings.left_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.left_image_alt | escape }}
        </div>
      {% endif %}

      <div class="sec-2-abo__content">
        {% if section.settings.eyebrow_text != blank %}
          <p class="sec-2-abo__eyebrow">{{ section.settings.eyebrow_text }}</p>
        {% endif %}

        {% if section.settings.title_prefix != blank or section.settings.title_highlight_1 != blank or section.settings.title_mid != blank or section.settings.title_highlight_2 != blank or section.settings.title_suffix != blank %}
          <h2 class="sec-2-abo__title">
            {% if section.settings.title_prefix != blank %}{{ section.settings.title_prefix }} {% endif %}
            {% if section.settings.title_highlight_1 != blank %}<span class="sec-2-abo__title-accent">{{ section.settings.title_highlight_1 }}</span>{% endif %}
            {% if section.settings.title_mid != blank %} {{ section.settings.title_mid }} {% endif %}
            {% if section.settings.title_highlight_2 != blank %}<span class="sec-2-abo__title-accent">{{ section.settings.title_highlight_2 }}</span>{% endif %}
            {% if section.settings.title_suffix != blank %} {{ section.settings.title_suffix }}{% endif %}
          </h2>
        {% endif %}

        {% if section.settings.body_text != blank %}
          <div class="sec-2-abo__body">{{ section.settings.body_text }}</div>
        {% endif %}
      </div>

      {% if section.settings.right_image != blank %}
        <div class="sec-2-abo__side-image sec-2-abo__side-image--right" aria-hidden="true">
          {{ section.settings.right_image | image_url: width: 800 | image_tag: loading: 'lazy', alt: section.settings.right_image_alt | escape }}
        </div>
      {% endif %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "About Story Section",
  "settings": [
    { "type": "header", "content": "Copy" },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow text", "default": "About Us" },
    { "type": "text", "id": "title_prefix", "label": "Title prefix", "default": "Meet" },
    { "type": "text", "id": "title_highlight_1", "label": "Title highlight 1", "default": "Feni" },
    { "type": "text", "id": "title_mid", "label": "Title middle", "default": "and" },
    { "type": "text", "id": "title_highlight_2", "label": "Title highlight 2", "default": "Scotch:" },
    { "type": "text", "id": "title_suffix", "label": "Title suffix", "default": "The Real Founders of Doggy Ji" },
    { "type": "richtext", "id": "body_text", "label": "Body text", "default": "<p>Doggy ji’s story began with two special companions—<strong>Feni and Scotch</strong>. Ram Narayan, the creator of Doggyji, found endless inspiration in his beloved dogs, who brought joy, love, and a deeper understanding of what dogs truly need.</p><p><strong>In their honour, he named his parent company, Fensco Foods (a blend of their names), as a tribute to the bond they share.</strong> To us, Feni and Scotch are the true founders of Doggyji—their unconditional love and playful spirits inspire everything we do.</p>" },
    { "type": "range", "id": "body_max_width", "label": "Body max width", "min": 400, "max": 1600, "step": 20, "unit": "px", "default": 1200 },
    { "type": "range", "id": "body_size", "label": "Body size", "min": 12, "max": 28, "step": 1, "unit": "px", "default": 16 },
    { "type": "range", "id": "body_line_height", "label": "Body line height", "min": 1, "max": 2, "step": 0.1, "default": 1.4 },
    { "type": "range", "id": "title_size", "label": "Title size", "min": 32, "max": 110, "step": 2, "unit": "px", "default": 72 },
    { "type": "range", "id": "subtitle_size", "label": "Eyebrow size", "min": 10, "max": 28, "step": 1, "unit": "px", "default": 16 },
    { "type": "header", "content": "Images" },
    { "type": "image_picker", "id": "left_image", "label": "Left image" },
    { "type": "text", "id": "left_image_alt", "label": "Left image alt text", "default": "Left dog photo" },
    { "type": "image_picker", "id": "right_image", "label": "Right image" },
    { "type": "text", "id": "right_image_alt", "label": "Right image alt text", "default": "Right dog photo" },
    { "type": "range", "id": "side_image_width", "label": "Side image width", "min": 120, "max": 520, "step": 10, "unit": "px", "default": 320 },
    { "type": "range", "id": "side_image_width_tablet", "label": "Side image width on tablet", "min": 100, "max": 360, "step": 10, "unit": "px", "default": 220 },
    { "type": "range", "id": "side_image_radius", "label": "Side image radius", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 22 },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "max_width", "label": "Section max width", "min": 1100, "max": 1800, "step": 20, "unit": "px", "default": 1600 },
    { "type": "range", "id": "content_max_width", "label": "Content max width", "min": 300, "max": 1000, "step": 20, "unit": "px", "default": 760 },
    { "type": "range", "id": "hero_min_height", "label": "Hero min height", "min": 240, "max": 900, "step": 10, "unit": "px", "default": 620 },
    { "type": "range", "id": "hero_padding_top", "label": "Hero top padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "hero_padding_bottom", "label": "Hero bottom padding", "min": 0, "max": 180, "step": 4, "unit": "px", "default": 40 },
    { "type": "range", "id": "content_padding_top", "label": "Content padding top", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "range", "id": "content_padding_bottom", "label": "Content padding bottom", "min": 0, "max": 120, "step": 4, "unit": "px", "default": 0 },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "background_color", "label": "Background color", "default": "#f7f1e3" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#101010" },
    { "type": "color", "id": "muted_color", "label": "Muted text color", "default": "#1d1d1d" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#ef5b00" },
    { "type": "image_picker", "id": "background_image", "label": "Background image" },
    { "type": "range", "id": "background_image_opacity", "label": "Background image opacity", "min": 0, "max": 100, "step": 5, "unit": "%", "default": 20 }
  ],
  "presets": [
    { "name": "About Story Section" }
  ]
}
{% endschema %}