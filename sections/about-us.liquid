			"max": 32,
			"step": 1,
			"unit": "px",
			"default": 16
		},
		{
			"type": "range",
			"id": "heading_size",
			"label": "Heading size",
			"min": 24,
			"max": 96,
			"step": 2,
			"unit": "px",
			"default": 68
		},
		{
			"type": "range",
			"id": "body_size",
			"label": "Body size",
			"min": 12,
			"max": 32,
			"step": 1,
			"unit": "px",
			"default": 17
		},
		{
			"type": "range",
			"id": "body_line_height",
			"label": "Body line height",
			"min": 1,
			"max": 2,
	      "step": 0.1,
