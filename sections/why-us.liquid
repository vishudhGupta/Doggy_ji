{%- liquid
	assign page_width = settings.page_width_main
	if section.settings.width != 'default'
		assign page_width = section.settings.width
	endif
-%}

<style>
	#minion-section-{{ section.id }} {
		position: relative;
		overflow: hidden;
		--why-bg: {{ section.settings.section_bg }};
		--why-subheading: {{ section.settings.subheading_color }};
		--why-heading: {{ section.settings.heading_color }};
		--why-card-gap: {{ section.settings.card_gap }}px;
		--why-card-radius: {{ section.settings.card_radius }}px;
		--why-card-padding: {{ section.settings.card_padding }}px;
		--why-bg-image-opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};
		--why-content-max: {{ section.settings.content_max_width }}px;
		--why-bg-image-x: {{ section.settings.bg_image_position_x }}%;
		--why-bg-image-y: {{ section.settings.bg_image_position_y }}%;
		background: var(--why-bg);
	}

	#minion-section-{{ section.id }} .why-us {
		position: relative;
		padding: clamp(26px, 4vw, 48px) clamp(16px, 3vw, 34px);
		z-index: 2;
	}

	#minion-section-{{ section.id }} .why-us__bg-image {
		position: absolute;
		left: var(--why-bg-image-x);
		top: var(--why-bg-image-y);
		transform: translate(0, 0);
		width: min(35vw, {{ section.settings.bg_image_size }}px);
		max-width: 100%;
		z-index: 1;
		opacity: var(--why-bg-image-opacity);
		pointer-events: none;
		transition: left 0.2s ease, top 0.2s ease;
	}

	#minion-section-{{ section.id }} .why-us__bg-image img {
		display: block;
		width: 100%;
		height: auto;
		max-width: none;
	}

	#minion-section-{{ section.id }} .why-us__inner {
		position: relative;
		z-index: 3;
		max-width: var(--why-content-max);
		margin: 0 auto;
	}

	#minion-section-{{ section.id }} .why-us__head {
		text-align: {{ section.settings.text_alignment }};
		margin-bottom: clamp(18px, 3vw, 34px);
	}

	#minion-section-{{ section.id }} .why-us__subheading {
		margin: 0;
		color: var(--why-subheading);
		letter-spacing: 0.08em;
		text-transform: uppercase;
		font-weight: 700;
		font-size: clamp(11px, 1.2vw, 14px);
	}

	#minion-section-{{ section.id }} .why-us__heading {
		margin: 8px 0 0;
		color: var(--why-heading);
		font-size: clamp(24px, 3.2vw, 48px);
		line-height: 1.15;
	}

	#minion-section-{{ section.id }} .why-us__cards {
		display: grid;
		grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
		gap: var(--why-card-gap);
		align-items: stretch;
	}

	#minion-section-{{ section.id }} .why-us__card {
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		min-height: {{ section.settings.card_min_height }}px;
		padding: var(--why-card-padding);
		border-radius: var(--why-card-radius);
		background: var(--why-card-bg, #184293);
		color: var(--why-card-text, #ffffff);
		border: 1px solid rgba(255, 255, 255, 0.12);
	}

	#minion-section-{{ section.id }} .why-us__value {
		margin: 0;
		font-weight: 800;
		font-size: clamp(30px, 4vw, 56px);
		line-height: 1;
		color: inherit;
	}

	#minion-section-{{ section.id }} .why-us__label {
		margin: 10px 0 0;
		font-weight: 600;
		font-size: clamp(14px, 1.3vw, 22px);
		line-height: 1.25;
		color: inherit;
	}

	@media (max-width: 1024px) {
		#minion-section-{{ section.id }} .why-us__cards {
			grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
		}

		#minion-section-{{ section.id }} .why-us__card {
			min-height: max({{ section.settings.card_min_height | minus: 20 }}px, 120px);
		}
	}

	@media (max-width: 767px) {
		#minion-section-{{ section.id }} .why-us {
			padding: 22px 12px;
		}

		#minion-section-{{ section.id }} .why-us__cards {
			grid-template-columns: repeat({{ section.settings.columns_mobile }}, minmax(0, 1fr));
		}

		#minion-section-{{ section.id }} .why-us__card {
			min-height: max({{ section.settings.card_min_height | minus: 36 }}px, 104px);
		}

		{% if section.settings.hide_bg_image_mobile %}
		#minion-section-{{ section.id }} .why-us__bg-image {
			display: none;
		}
		{% else %}
		#minion-section-{{ section.id }} .why-us__bg-image {
			left: {{ section.settings.bg_image_position_x_mobile }}%;
			top: {{ section.settings.bg_image_position_y_mobile }}%;
			transform: translate(0, 0);
			width: min(54vw, {{ section.settings.bg_image_size_mobile }}px);
		}
		{% endif %}
	}
</style>

<section id="minion-section-{{ section.id }}" class="top-spacing-{{ section.settings.top_spacing }}" data-section-name="why-us">
	{%- if section.settings.bg_image != blank -%}
		<div class="why-us__bg-image" aria-hidden="true">
			{{
				section.settings.bg_image
				| image_url: width: 1000
				| image_tag:
					loading: 'lazy',
					widths: '280,420,600,800,1000',
					sizes: '(max-width: 767px) 54vw, 32vw',
					alt: section.settings.bg_image.alt
			}}
		</div>
	{%- endif -%}

	<div class="{{ page_width }}">
		<div class="why-us mb--last-child-0">
			<div class="why-us__inner">
				<div class="why-us__head">
					{%- if section.settings.subheading != blank -%}
						<p class="why-us__subheading">{{ section.settings.subheading }}</p>
					{%- endif -%}
					{%- if section.settings.heading != blank -%}
						<h2 class="why-us__heading">{{ section.settings.heading }}</h2>
					{%- endif -%}
				</div>

				{%- if section.blocks.size > 0 -%}
					<div class="why-us__cards">
						{%- for block in section.blocks -%}
							<article
								class="why-us__card"
								style="--why-card-bg: {{ block.settings.card_bg }}; --why-card-text: {{ block.settings.card_text_color }};"
								{{ block.shopify_attributes }}
							>
								<p class="why-us__value">{{ block.settings.stat_value }}</p>
								<p class="why-us__label">{{ block.settings.stat_label }}</p>
							</article>
						{%- endfor -%}
					</div>
				{%- endif -%}
			</div>
		</div>
	</div>
</section>

{% schema %}
{
	"name": "Why Us",
	"tag": "section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "text",
			"id": "subheading",
			"label": "Subheading",
			"default": "WHY DROOLS?"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Know Why Pet Owners Trust Drools"
		},
		{
			"type": "select",
			"id": "text_alignment",
			"label": "Heading alignment",
			"default": "center",
			"options": [
				{ "value": "left", "label": "Left" },
				{ "value": "center", "label": "Center" }
			]
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "top_spacing",
			"label": "Top spacing",
			"default": "normal",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "small", "label": "Small" },
				{ "value": "medium", "label": "Medium" },
				{ "value": "normal", "label": "Normal" }
			]
		},
		{
			"type": "select",
			"id": "width",
			"label": "Content width",
			"default": "default",
			"options": [
				{ "value": "default", "label": "Theme default" },
				{ "value": "page-width", "label": "Boxed" },
				{ "value": "page-wide", "label": "Wide" }
			]
		},
		{
			"type": "range",
			"id": "content_max_width",
			"min": 600,
			"max": 1800,
			"step": 20,
			"unit": "px",
			"label": "Content max width",
			"default": 1200
		},
		{
			"type": "range",
			"id": "columns_desktop",
			"min": 1,
			"max": 4,
			"step": 1,
			"label": "Desktop columns",
			"default": 3
		},
		{
			"type": "range",
			"id": "columns_tablet",
			"min": 1,
			"max": 3,
			"step": 1,
			"label": "Tablet columns",
			"default": 3
		},
		{
			"type": "range",
			"id": "columns_mobile",
			"min": 1,
			"max": 3,
			"step": 1,
			"label": "Mobile columns",
			"default": 1
		},
		{
			"type": "range",
			"id": "card_gap",
			"min": 4,
			"max": 40,
			"step": 1,
			"unit": "px",
			"label": "Card gap",
			"default": 16
		},
		{
			"type": "range",
			"id": "card_padding",
			"min": 8,
			"max": 60,
			"step": 1,
			"unit": "px",
			"label": "Card padding",
			"default": 20
		},
		{
			"type": "range",
			"id": "card_radius",
			"min": 0,
			"max": 40,
			"step": 1,
			"unit": "px",
			"label": "Card corner radius",
			"default": 14
		},
		{
			"type": "range",
			"id": "card_min_height",
			"min": 100,
			"max": 320,
			"step": 10,
			"unit": "px",
			"label": "Card minimum height",
			"default": 170
		},
		{
			"type": "header",
			"content": "Background image"
		},
		{
			"type": "image_picker",
			"id": "bg_image",
			"label": "Background image"
		},
		{
			"type": "range",
			"id": "bg_image_size",
			"min": 120,
			"max": 900,
			"step": 10,
			"unit": "px",
			"label": "Background image size (desktop)",
			"default": 420
		},
		{
			"type": "range",
			"id": "bg_image_position_x",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Background image horizontal position (desktop)",
			"default": 10
		},
		{
			"type": "range",
			"id": "bg_image_position_y",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Background image vertical position (desktop)",
			"default": 80
		},
		{
			"type": "range",
			"id": "bg_image_size_mobile",
			"min": 100,
			"max": 480,
			"step": 10,
			"unit": "px",
			"label": "Background image size (mobile)",
			"default": 260
		},
		{
			"type": "range",
			"id": "bg_image_position_x_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Background image horizontal position (mobile)",
			"default": 12
		},
		{
			"type": "range",
			"id": "bg_image_position_y_mobile",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Background image vertical position (mobile)",
			"default": 84
		},
		{
			"type": "range",
			"id": "bg_image_opacity",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"label": "Background image opacity",
			"default": 100
		},
		{
			"type": "checkbox",
			"id": "hide_bg_image_mobile",
			"label": "Hide background image on mobile",
			"default": false
		},
		{
			"type": "header",
			"content": "Colors"
		},
		{
			"type": "color",
			"id": "section_bg",
			"label": "Section background",
			"default": "#ececef"
		},
		{
			"type": "color",
			"id": "subheading_color",
			"label": "Subheading color",
			"default": "#ea3d3d"
		},
		{
			"type": "color",
			"id": "heading_color",
			"label": "Heading color",
			"default": "#0b0d12"
		}
	],
	"blocks": [
		{
			"type": "stat",
			"name": "Stat card",
			"limit": 8,
			"settings": [
				{
					"type": "text",
					"id": "stat_value",
					"label": "Value",
					"default": "65M+"
				},
				{
					"type": "text",
					"id": "stat_label",
					"label": "Label",
					"default": "Happy Pet Owners"
				},
				{
					"type": "color",
					"id": "card_bg",
					"label": "Card background",
					"default": "#15408c"
				},
				{
					"type": "color",
					"id": "card_text_color",
					"label": "Card text color",
					"default": "#ffffff"
				}
			]
		}
	],
	"presets": [
		{
			"name": "Why Us",
			"blocks": [
				{
					"type": "stat",
					"settings": {
						"stat_value": "65M+",
						"stat_label": "Happy Pet Owners"
					}
				},
				{
					"type": "stat",
					"settings": {
						"stat_value": "99%",
						"stat_label": "Pincodes Covered"
					}
				},
				{
					"type": "stat",
					"settings": {
						"stat_value": "42+",
						"stat_label": "Years of Experience"
					}
				}
			]
		}
	]
}
{% endschema %}
