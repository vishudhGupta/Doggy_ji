        "type": "select",
        "id": "heading_aligment",
        "options": [
          {
          "value": "text-left",
          "label": "t:sections.general.settings.texts_aligment.options__left.label"
          },
          {
          "value": "text-center",
          "label": "t:sections.general.settings.texts_aligment.options__center.label"
          }
