{%- capture section_styles -%}
#minion-section-{{ section.id }} {
	--bwt-height-desktop: {{ section.settings.banner_height_desktop }}px;
	--bwt-height-mobile: {{ section.settings.banner_height_mobile }}px;
	--bwt-radius: {{ section.settings.border_radius }}px;
	--bwt-content-x: {{ section.settings.content_x }}%;
	--bwt-content-y: {{ section.settings.content_y }}%;
	--bwt-content-x-mobile: {{ section.settings.content_x_mobile }}%;
	--bwt-content-y-mobile: {{ section.settings.content_y_mobile }}%;
	--bwt-content-width: {{ section.settings.content_width }}%;
	--bwt-content-width-mobile: {{ section.settings.content_width_mobile }}%;
	--bwt-heading-size: {{ section.settings.heading_size }}px;
	--bwt-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
	--bwt-text-size: {{ section.settings.text_size }}px;
	--bwt-text-size-mobile: {{ section.settings.text_size_mobile }}px;
	--bwt-text-color: {{ section.settings.text_color }};
	--bwt-bullet-color: {{ section.settings.bullet_color }};
	--bwt-button-bg: {{ section.settings.button_bg }};
	--bwt-button-color: {{ section.settings.button_color }};
	--bwt-overlay-bg: {{ section.settings.overlay_bg }};
	--bwt-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
}

#minion-section-{{ section.id }} .bwt {
	position: relative;
	border-radius: var(--bwt-radius);
	overflow: hidden;
	min-height: var(--bwt-height-desktop);
	background: #f0f0f0;
}

#minion-section-{{ section.id }} .bwt__fullwidth {
	width: 100%;
	max-width: 100%;
	padding-left: 0;
	padding-right: 0;
}

#minion-section-{{ section.id }} .bwt__media,
#minion-section-{{ section.id }} .bwt__media picture,
#minion-section-{{ section.id }} .bwt__media img {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
}

#minion-section-{{ section.id }} .bwt__media img {
	object-fit: cover;
	object-position: center;
}

#minion-section-{{ section.id }} .bwt__overlay {
	position: absolute;
	inset: 0;
	background: var(--bwt-overlay-bg);
	opacity: var(--bwt-overlay-opacity);
	pointer-events: none;
}

#minion-section-{{ section.id }} .bwt__content {
	position: absolute;
	left: var(--bwt-content-x);
	top: var(--bwt-content-y);
	transform: translate(-50%, -50%);
	width: min(var(--bwt-content-width), 560px);
	max-width: calc(100% - 24px);
	color: var(--bwt-text-color);
	text-align: {{ section.settings.text_alignment }};
	z-index: 2;
}

#minion-section-{{ section.id }} .bwt__subheading {
	margin: 0 0 6px;
	font-size: calc(var(--bwt-text-size) - 1px);
	line-height: 1.25;
	font-weight: 600;
}

#minion-section-{{ section.id }} .bwt__heading {
	margin: 0;
	color: inherit;
	font-size: var(--bwt-heading-size);
	line-height: 1.15;
	font-weight: 700;
}

#minion-section-{{ section.id }} .bwt__description {
	margin: 10px 0 0;
	font-size: var(--bwt-text-size);
	line-height: 1.45;
}

#minion-section-{{ section.id }} .bwt__description p {
	margin: 0;
}

#minion-section-{{ section.id }} .bwt__points {
	margin: 12px 0 0;
	padding: 0;
	list-style: none;
	display: grid;
	gap: 6px;
	font-size: var(--bwt-text-size);
	line-height: 1.3;
}

#minion-section-{{ section.id }} .bwt__point {
	display: flex;
	align-items: flex-start;
	gap: 8px;
}

#minion-section-{{ section.id }} .bwt__dot {
	flex: 0 0 auto;
	width: 11px;
	height: 11px;
	margin-top: 2px;
	border-radius: 50%;
	background: var(--bwt-bullet-color);
}

#minion-section-{{ section.id }} .bwt__button-wrap {
	margin-top: 14px;
}

#minion-section-{{ section.id }} .bwt__button {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	min-height: 40px;
	padding: 9px 18px;
	border-radius: 8px;
	background: var(--bwt-button-bg);
	color: var(--bwt-button-color);
	font-size: 14px;
	font-weight: 600;
	line-height: 1;
	text-decoration: none;
	border: 0;
}

#minion-section-{{ section.id }} .bwt__button[aria-disabled="true"] {
	opacity: 0.55;
	pointer-events: none;
}

@media (max-width: 767px) {
	#minion-section-{{ section.id }} .bwt {
		min-height: var(--bwt-height-mobile);
	}

	#minion-section-{{ section.id }} .bwt__content {
		left: var(--bwt-content-x-mobile);
		top: var(--bwt-content-y-mobile);
		width: var(--bwt-content-width-mobile);
		max-width: calc(100% - 20px);
	}

	#minion-section-{{ section.id }} .bwt__subheading {
		font-size: max(calc(var(--bwt-text-size-mobile) - 1px), 11px);
		margin-bottom: 4px;
	}

	#minion-section-{{ section.id }} .bwt__heading {
		font-size: var(--bwt-heading-size-mobile);
	}

	#minion-section-{{ section.id }} .bwt__description,
	#minion-section-{{ section.id }} .bwt__points {
		font-size: var(--bwt-text-size-mobile);
	}

	#minion-section-{{ section.id }} .bwt__points {
		gap: 4px;
		margin-top: 8px;
	}

	#minion-section-{{ section.id }} .bwt__dot {
		width: 9px;
		height: 9px;
		margin-top: 3px;
	}

	#minion-section-{{ section.id }} .bwt__button-wrap {
		margin-top: 10px;
	}

	#minion-section-{{ section.id }} .bwt__button {
		min-height: 34px;
		padding: 8px 14px;
		font-size: 12px;
	}
}
{%- endcapture -%}

<style>
	{{ section_styles }}
</style>

<div id="minion-section-{{ section.id }}" class="top-spacing-{{ section.settings.top_spacing }}" data-section-name="banner-with-text">
	<div class="bwt__fullwidth">
		<div class="bwt mb--last-child-0">
			<div class="bwt__media" aria-hidden="true">
				{%- if section.settings.image != blank -%}
					{%- if section.settings.image_mobile != blank -%}
						<picture>
							<source media="(max-width: 767px)" srcset="{{ section.settings.image_mobile | image_url: width: 1100 }}">
							{{
								section.settings.image
								| image_url: width: 2200
								| image_tag:
									loading: 'lazy',
									widths: '480,768,1024,1400,1800,2200',
									sizes: '100vw',
									alt: section.settings.heading
							}}
						</picture>
					{%- else -%}
						{{
							section.settings.image
							| image_url: width: 2200
							| image_tag:
								loading: 'lazy',
								widths: '480,768,1024,1400,1800,2200',
								sizes: '100vw',
								alt: section.settings.heading
						}}
					{%- endif -%}
				{%- else -%}
					{%- render 'icons-placeholder-other', icon_name: 'image-1' -%}
				{%- endif -%}
			</div>

			<div class="bwt__overlay"></div>

			<div class="bwt__content">
				{%- if section.settings.subheading != blank -%}
					<p class="bwt__subheading">{{ section.settings.subheading }}</p>
				{%- endif -%}

				{%- if section.settings.heading != blank -%}
					<h2 class="bwt__heading">{{ section.settings.heading }}</h2>
				{%- endif -%}

				{%- if section.settings.description != blank -%}
					<div class="bwt__description rte">{{ section.settings.description }}</div>
				{%- endif -%}

				{%- if section.settings.bullet_points != blank -%}
					<ul class="bwt__points" role="list">
						{%- assign bullet_lines = section.settings.bullet_points | newline_to_br | split: '<br />' -%}
						{%- for line in bullet_lines -%}
							{%- assign clean_line = line | strip -%}
							{%- if clean_line != blank -%}
								<li class="bwt__point">
									<span class="bwt__dot" aria-hidden="true"></span>
									<span>{{ clean_line }}</span>
								</li>
							{%- endif -%}
						{%- endfor -%}
					</ul>
				{%- endif -%}

				{%- if section.settings.button_label != blank -%}
					<div class="bwt__button-wrap">
						<a class="bwt__button" href="{{ section.settings.button_link | default: '#' }}"{% if section.settings.button_link == blank %} aria-disabled="true"{% endif %}>{{ section.settings.button_label }}</a>
					</div>
				{%- endif -%}
			</div>
		</div>
	</div>
</div>

{% schema %}
{
	"name": "Banner with text",
	"tag": "section",
	"disabled_on": {
		"groups": ["header", "footer"]
	},
	"settings": [
		{
			"type": "header",
			"content": "Content"
		},
		{
			"type": "text",
			"id": "subheading",
			"label": "Subheading",
			"default": "Subscription"
		},
		{
			"type": "text",
			"id": "heading",
			"label": "Heading",
			"default": "Never Run Out Of Treats!"
		},
		{
			"type": "richtext",
			"id": "description",
			"label": "Description",
			"default": "<p>Save 15% on every order and enjoy reliable delivery.</p>"
		},
		{
			"type": "textarea",
			"id": "bullet_points",
			"label": "Bullet points (one per line)",
			"default": "Save 15% on every order\nFree shipping\nFlexible delivery\nCancel anytime"
		},
		{
			"type": "text",
			"id": "button_label",
			"label": "Button label",
			"default": "Start Subscription"
		},
		{
			"type": "url",
			"id": "button_link",
			"label": "Button link"
		},
		{
			"type": "header",
			"content": "Images"
		},
		{
			"type": "image_picker",
			"id": "image",
			"label": "Banner image (desktop)"
		},
		{
			"type": "image_picker",
			"id": "image_mobile",
			"label": "Banner image (mobile, optional)"
		},
		{
			"type": "header",
			"content": "Layout"
		},
		{
			"type": "select",
			"id": "top_spacing",
			"label": "Top spacing",
			"default": "normal",
			"options": [
				{ "value": "none", "label": "None" },
				{ "value": "small", "label": "Small" },
				{ "value": "medium", "label": "Medium" },
				{ "value": "normal", "label": "Normal" }
			]
		},
		{
			"type": "select",
			"id": "width",
			"label": "Content width",
			"default": "default",
			"options": [
				{ "value": "default", "label": "Theme default" },
				{ "value": "page-width", "label": "Boxed" },
				{ "value": "page-wide", "label": "Wide" }
			]
		},
		{
			"type": "range",
			"id": "banner_height_desktop",
			"label": "Banner height desktop",
			"min": 220,
			"max": 650,
			"step": 10,
			"unit": "px",
			"default": 360
		},
		{
			"type": "range",
			"id": "banner_height_mobile",
			"label": "Banner height mobile",
			"min": 180,
			"max": 520,
			"step": 10,
			"unit": "px",
			"default": 280
		},
		{
			"type": "range",
			"id": "border_radius",
			"label": "Banner corner radius",
			"min": 0,
			"max": 40,
			"step": 1,
			"unit": "px",
			"default": 14
		},
		{
			"type": "header",
			"content": "Text placement"
		},
		{
			"type": "select",
			"id": "text_alignment",
			"label": "Text alignment",
			"default": "left",
			"options": [
				{ "value": "left", "label": "Left" },
				{ "value": "center", "label": "Center" },
				{ "value": "right", "label": "Right" }
			]
		},
		{
			"type": "range",
			"id": "content_x",
			"label": "Desktop text horizontal position",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"default": 38
		},
		{
			"type": "range",
			"id": "content_y",
			"label": "Desktop text vertical position",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"default": 52
		},
		{
			"type": "range",
			"id": "content_width",
			"label": "Desktop text width",
			"min": 20,
			"max": 80,
			"step": 1,
			"unit": "%",
			"default": 42
		},
		{
			"type": "range",
			"id": "content_x_mobile",
			"label": "Mobile text horizontal position",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"default": 50
		},
		{
			"type": "range",
			"id": "content_y_mobile",
			"label": "Mobile text vertical position",
			"min": 0,
			"max": 100,
			"step": 1,
			"unit": "%",
			"default": 52
