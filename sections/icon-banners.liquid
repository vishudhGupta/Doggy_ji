{%- if settings.animate_content_show -%}
<link rel="stylesheet" href="{{ 'section-icon-banners.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'section-icon-banners.css' | asset_url | stylesheet_tag }}</noscript>
{%- if section.settings.swipe_on_mobile -%}
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
{%- endif -%}
{%- else -%}
{{ 'section-icon-banners.css' | asset_url | stylesheet_tag }}
{%- if section.settings.swipe_on_mobile -%}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{%- endif -%}
{%- endif -%}

{%- render "section-background" section:section -%}

{%- capture section_styles -%}
{%- if section.settings.color_svg != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .icon-banners__icon svg path{
--color-base: {{ section.settings.color_svg }};
}
{%- endif -%}
{%- if section.settings.color_heading_banner != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .icon-banners__heading{
--color-base: {{ section.settings.color_heading_banner }};
}
{%- endif -%}
{%- if section.settings.color_button != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .btn-medium{
--color-accent: {{ section.settings.color_button }};
}
{%- endif -%}
{%- if section.settings.color_item_bg != "rgba(0,0,0,0)" or section.settings.color_item_border != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .icon-banners:before{
  {%- if section.settings.color_item_bg != "rgba(0,0,0,0)" -%}
  background:{{ section.settings.color_item_bg }};
  {%- endif -%}
  {%- if section.settings.color_item_border != "rgba(0,0,0,0)" -%}
  border-color:{{ section.settings.color_item_border }};
  {%- else -%}
  border-color:{{ settings.color_base | color_modify: 'alpha', 0.3 }};
  {%- endif -%}
  opacity:1;
}
{%- endif -%}
{%- if section.settings.color_text_banner != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .icon-banners__description{
  color:{{ section.settings.color_text_banner }};
}
{%- endif -%}
{%- if section.settings.color_swipe_buttons  != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .slider__button{
  --color-base:{{ section.settings.color_swipe_buttons }};
}
{%- endif -%}
{%- endcapture -%}
{%- if section_styles != blank -%}
<style>{{ section_styles }}</style>
{%- endif -%}

{%- liquid
    if section.settings.grid == "grid-columns-2"
    assign grid = "col-sp-12 col-md-6 col-6"
    elsif section.settings.grid == "grid-columns-3"
    assign grid = "col-sp-12 col-md-6 col-4"
    elsif section.settings.grid == "grid-columns-4"
    assign grid = "col-sp-12 col-md-6 col-3"
    endif
-%}
<div id="minion-section-{{ section.id }}" class="top-spacing-{{ section.settings.top_spacing }}{% if section.settings.background != 'hide' and section.settings.background_width == "fullwidth" %} section-background section-background--{{ section.settings.background_spacing }}{% endif %}"
     data-section-name="icon-banners">
  <div class="{% if section.settings.width != "default" %}{{ section.settings.width }}{% else %}{{ settings.page_width_main }}{% endif %} mb--last-child-0">
    {% if section.settings.background != 'hide' and section.settings.background_width == "content_width" %}<div class="section-background section-background--{{ section.settings.background_spacing }} border__radius mb--last-child-0">{%- endif -%}
  
    {%- render "section-heading" section:section -%}
    
    {%- if section.blocks.size > 0 -%}
    <slider-component class="el_mt_auto grid {{ section.settings.texts_aligment }} grid-container{% if section.settings.swipe_on_mobile %} slider slider--phone{% endif %}{% if section.settings.heading_aligment == "text-center" %} justify-content-center--no-phone{% endif %}">
      {%- for block in section.blocks -%}
        <div class="{{ grid }}{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}">
        {%- if block.settings.url != blank -%}
        {%- assign html_tag_open = '<a' | append: ' href="' | append: block.settings.url | append:'"' -%}
        {%- assign html_tag_close = '</a>' -%}
        {%- else -%}
        {%- assign html_tag_open = '<div' -%}
        {%- assign html_tag_close = '</div>' -%}
        {%- endif -%}
      
		{{ html_tag_open }} class="icon-banners mb--last-child-0 border__radius hover-area{% if settings.enable_zoom_animation %} scale-border-hover{% endif %} {{ section.settings.texts_aligment_vertical }}" {{ block.shopify_attributes }}>
      
      	  {%- if block.settings.show_icon == 'image' and block.settings.image != blank -%}
            
          <div class="icon-banners__icon icon-banners__icon__animation mb20">
            {%- capture icon_code -%}
            {%- assign image = block.settings.image -%}
            {%- assign imagesize = block.settings.image.width | append: 'x' -%}
            {%- capture srcset -%}{{ block.settings.image | img_url: imagesize }} 1x, {{ block.settings.image | img_url: imagesize, scale: 2 }} 2x{%- endcapture -%}
            {{
              image
              | image_url: width: image.width
              | image_tag:
                loading: 'lazy',
                width: image.width,
                height: image.height,
                srcset: srcset
            }}
            {% endcapture %}
            {{ icon_code }}
            <div class="icon-banners__icon__animation__item">
            {{ icon_code }}
            </div>
          </div>
          {%- elsif block.settings.show_icon == 'svg' and block.settings.icon_name != blank -%}
          <div class="icon-banners__icon icon-banners__icon__animation mb20 svg-icon--normal">
            {%- render 'icons-list' icon_name: block.settings.icon_name -%}
            <div class="icon-banners__icon__animation__item">
              {%- render 'icons-list' icon_name: block.settings.icon_name -%}
            </div>
          </div>
          {%- endif -%}

          <div class="mt--first-child-0">
            {%- if block.settings.heading != blank -%}
            {{ '<' | append: section.settings.heading_tag }} class="icon-banners__heading mb0 {% if section.settings.hover_underline %} animation-underline{% endif %}">
            {{ block.settings.heading }}
            {{ '</' | append: section.settings.heading_tag }}>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
            <p class="mt10 icon-banners__description{% if section.settings.description_size != "normal" %} {{ section.settings.description_size }}{% endif %}">
              {{ block.settings.description }}
            </p>
            {%- endif -%}

            {%- if block.settings.button_name != blank and block.settings.url != blank -%}
            <div class="mt20">
              <div class="btn-medium hover-area--native">{{ block.settings.button_name }}</div>
            </div>
            {%- endif -%}
          </div>
        {{ html_tag_close }}
        </div>
      {%- endfor -%}

    </slider-component>
    {%- assign length = section.blocks.size | divided_by: 1.0 | ceil -%}
    {%- if section.settings.swipe_on_mobile and length > 1 -%}
    <div class="mt40 grid slider__buttons slider--phone">
      <div class="col-12">
        {%- liquid
            capture alignment
            if section.settings.heading_aligment == "text-center"
            echo "justify-content-center"
            endif
          	endcapture
          	render "slider-buttons", alignment:alignment, length:length
        -%}
      </div>
    </div>
    {%- endif -%}

    {%- endif -%}
    {% if section.settings.background != 'hide' and section.settings.background_width == "content_width" %}</div>{%- endif -%}
  </div>
</div>

