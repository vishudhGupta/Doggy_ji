{%- if settings.animate_content_show -%}
{%- if section.settings.swipe_on_mobile -%}
<link rel="stylesheet" href="{{ 'component-slider.css' | asset_url }}" media="print" onload="this.media='all'">
<noscript>{{ 'component-slider.css' | asset_url | stylesheet_tag }}</noscript>
{%- endif -%}
{%- else -%}
{%- if section.settings.swipe_on_mobile -%}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{%- endif -%}
{%- endif -%}

{%- render "section-background" section:section -%}

{%- capture section_styles -%}
{%- if section.settings.color_svg != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .text-columns-img__icon svg path{
--color-base: {{ section.settings.color_svg }};
}
{%- endif -%}
{%- if section.settings.color_heading_blurb != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .text-columns-img__heading{
  --color-base:{{section.settings.color_heading_blurb}};
}
{%- endif -%}
{%- if section.settings.color_description != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .text-columns-img__description{
  color:{{section.settings.color_description}};
}
{%- endif -%}
{%- if section.settings.color_swipe_buttons != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .slider__button{
  --color-base: {{ section.settings.color_swipe_buttons }};
}
{%- endif -%}
{%- if section.settings.color_counter != "rgba(0,0,0,0)" -%}
#minion-section-{{ section.id }} .counter-showcase__count{
  --color-count: {{ section.settings.color_counter }};
}
{%- endif -%}
{%- endcapture -%}
<style>
  .text-columns-img__icon{
    display:flex;
  }
  .text-columns-img__icon img{
    object-fit: cover;
  }
  #minion-section-{{ section.id }} .text-columns-img__icon svg{
    max-width:unset;
    max-height:unset;
  }
  .counter-showcase__container{
    display:flex;
    row-gap: 0;
    column-gap: 10px;
    flex-wrap:wrap;
    align-items:center;
  }
  .counter-showcase__count{
    display:block;
    color: var(--color-count, var(--color-accent));
  }
  @media (min-width:577px){
    #minion-section-{{ section.id }} .text-columns-img__icon img,
    #minion-section-{{ section.id }} .text-columns-img__icon svg{
        width:{{ section.settings.icon_size }}px;
        height:{{ section.settings.icon_size }}px;
    }
    #minion-section-{{ section.id }} .counter-showcase__count{
        font-size:{{ section.settings.icon_size }}px;
    }
  }
  @media (max-width:576px){
    #minion-section-{{ section.id }} .text-columns-img__icon img,
    #minion-section-{{ section.id }} .text-columns-img__icon svg{
        width:{{ section.settings.icon_size_mobile }}px;
        height:{{ section.settings.icon_size_mobile }}px;
    }
    #minion-section-{{ section.id }} .counter-showcase__count{
        font-size:{{ section.settings.icon_size_mobile }}px;
    }
  }
  {{ section_styles }}
</style>

{%- capture page_width -%}{%- if section.settings.width != "default" %}{{ section.settings.width }}{%- else -%}{{ settings.page_width_main }}{%- endif -%}{%- endcapture -%}
<div id="minion-section-{{ section.id }}" class="top-spacing-{{ section.settings.top_spacing }}{% if section.settings.background != 'hide' and section.settings.background_width == "fullwidth" %} section-background section-background--{{ section.settings.background_spacing }}{% endif %}"
     data-section-name="counter-showcase">
  <div class="{{ page_width }} mb--last-child-0">
    {% if section.settings.background != 'hide' and section.settings.background_width == "content_width" %}<div class="section-background section-background--{{ section.settings.background_spacing }} border__radius mb--last-child-0">{%- endif -%}
    
    {%- render "section-heading" section:section -%}
    
    {%- if section.blocks.size > 0 -%}
    <slider-component class="grid el_mt_40 {{ section.settings.texts_aligment }}{% if section.settings.swipe_on_mobile %} slider slider--phone{% endif %}{% if section.settings.heading_aligment == "text-center" %} justify-content-center--no-phone{% endif %}">
      {%- for block in section.blocks -%}
      <div class="col-sp-12 {{ section.settings.grid_tablet }} {{ section.settings.grid }}{% if section.settings.swipe_on_mobile %} slider__slide{% endif %}" {{ block.shopify_attributes }}>
        {%- case block.type -%}
        {%- when 'blurb_icon' -%}
        <div class="text-columns-icons mb--last-child-0 hover-area">
            {%- capture icon -%}
            {%- if block.settings.show_icon == 'image' and block.settings.image != blank -%}
            <div class="text-columns-img__icon">
                {%- assign image = block.settings.image -%}
                {%- assign imagesize = block.settings.image.width | append: 'x' -%}
                {%- capture srcset -%}{{ block.settings.image | img_url: imagesize }} 1x, {{ block.settings.image | img_url: imagesize, scale: 2 }} 2x{%- endcapture -%}
                {%- capture image_class -%}{% if settings.animate_image_show %}image-show--fadein{% endif %}{%- endcapture -%}
                {%- capture animate_image_show -%}{% if settings.animate_image_show %}this.classList.add('image-loaded');{% endif %}{%- endcapture -%}
                {{
                image
                | image_url: width: image.width
                | image_tag:
                    loading: 'lazy',
                    width: image.width,
                    height: image.height,
                    srcset: srcset,
                    class: image_class,
                    onload: animate_image_show
                }}
            </div>
            {%- elsif block.settings.show_icon == 'svg' and block.settings.icon_name != blank -%}
            <div class="text-columns-img__icon svg-icon--normal">
                {%- render 'icons-list' icon_name: block.settings.icon_name -%}
            </div>
            {%- endif -%}
            {%- endcapture -%}
            {%- capture counter -%}
            {%- if block.settings.counterstart != blank -%}
            <section-counter class="counter-showcase__count h5"
                            data-counterstart="{{ block.settings.counterstart }}"
                            data-counterend="{{ block.settings.counterend }}"
                            data-decimal_places="{{ block.settings.decimal_places }}"
                            data-separator="{{ block.settings.separator }}"
                            data-decimal="{{ block.settings.decimal }}"
                            data-grouping="{{ block.settings.grouping }}"
                            data-suffix="{{ block.settings.suffix }}"
                            data-prefix="{{ block.settings.prefix }}">{{ block.settings.counterstart }}</section-counter>
            {%- endif -%}
            {%- endcapture -%}
            {%- if icon != blank or counter != blank -%}
            <div class="counter-showcase__container mb10{% if section.settings.texts_aligment == "text-center" %} justify-content-center{% endif %}">
                {{ icon }}
                {{ counter }}
            </div>
            {%- endif -%}

          <div class="mt--first-child-0">
            {%- if block.settings.heading != blank -%}
            {{ '<' | append: section.settings.heading_tag }} class="text-columns-img__heading mt0 mb0{% if section.settings.hover_underline and block.settings.url != blank %} animation-underline{% endif %}">
            {%- if block.settings.url != blank -%}<a href="{{ block.settings.url }}" class="clear-underline" aria-label="{{ 'general.aria_label.link' | t }}">{%- endif -%}
            {{ block.settings.heading }}
            {%- if block.settings.url != blank -%}</a>{%- endif -%}
            {{ '</' | append: section.settings.heading_tag }}>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
            <div class="mt10 text-columns-img__description section__richtext__editor mt--first-child-0{% if section.settings.description_size != "normal" %} {{ section.settings.description_size }}{% endif %}">
              {{ block.settings.description }}
            </div>
            {%- endif -%}
          </div>
        </div>

        {%- endcase -%}
      </div>
      
      {%- endfor -%}
    </slider-component>

    {%- assign length = section.blocks.size | divided_by: 1.0 | ceil -%}
    {%- if section.settings.swipe_on_mobile and length > 1 -%}
    <div class="mt40 grid slider__buttons slider--phone">
      <div class="col-12">
        {%- liquid
            capture alignment
            if section.settings.heading_aligment == "text-center"
            echo "justify-content-center"
            endif
          	endcapture
          	render "slider-buttons", alignment:alignment, length:length
        -%}
      </div>
    </div>
    {%- endif -%}

    {%- endif -%}
    {% if section.settings.background != 'hide' and section.settings.background_width == "content_width" %}</div>{%- endif -%}
  </div>
</div>

