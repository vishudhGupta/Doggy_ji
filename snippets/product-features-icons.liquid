{%- if block and block.settings -%}
{%- capture icons_content -%}
{%- for i in (1..3) -%}
{%- assign icon_image_key = "icon_" | append: i | append: "_image" -%}
{%- assign icon_text_key = "icon_" | append: i | append: "_text" -%}
{%- assign icon_image = block.settings[icon_image_key] -%}
{%- assign icon_text = block.settings[icon_text_key] -%}
{%- if icon_image or icon_text -%}
<div class="feature-icon-item">
  {%- if icon_image -%}
  <div class="feature-icon-image">
    <img src="{{ icon_image | image_url: width: 80 }}" alt="{{ icon_text }}">
  </div>
  {%- endif -%}
  {%- if icon_text -%}
  <p class="feature-icon-text">{{ icon_text }}</p>
  {%- endif -%}
</div>
{%- endif -%}
{%- endfor -%}
{%- endcapture -%}

{%- if icons_content != blank -%}
<div class="product-features-icons">
  {{ icons_content }}
</div>
{%- endif -%}
{%- endif -%}
