          },
          {
            "value": "text-center",
            "label": "t:sections.general.settings.texts_aligment.options__center.label"
          }
        ],
        "default": "text-center",
        "label": "t:sections.general.settings.texts_aligment.label"
      },
      {
        "type": "select",
