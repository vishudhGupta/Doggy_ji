{%- liquid
	assign page_width = settings.page_width_main
	if section.settings.width != 'default'
		assign page_width = section.settings.width
	endif
-%}

{%- capture section_styles -%}
#minion-section-{{ section.id }} {
	--sbp-section-bg: {{ section.settings.section_background }};
	--sbp-heading-color: {{ section.settings.heading_color }};
	--sbp-subheading-color: {{ section.settings.subheading_color }};
	--sbp-card-radius: {{ section.settings.card_radius }}px;
	--sbp-card-gap: {{ section.settings.card_gap }}px;
	--sbp-card-min-height: {{ section.settings.card_min_height }}px;
	--sbp-content-padding: {{ section.settings.content_padding }}px;
	--sbp-image-width: {{ section.settings.image_width }}%;
	--sbp-icon-opacity: {{ section.settings.icon_group_opacity | divided_by: 100.0 }};
}

#minion-section-{{ section.id }} .shop-by-pet__surface {
	position: relative;
	overflow: hidden;
	background: var(--sbp-section-bg);
	border-radius: var(--radius);
	padding: clamp(20px, 3vw, 34px);
}

#minion-section-{{ section.id }} .shop-by-pet__header {
	margin-bottom: 22px;
}

#minion-section-{{ section.id }} .shop-by-pet__heading {
	margin: 0;
	color: var(--sbp-heading-color);
	font-weight: 700;
}

#minion-section-{{ section.id }} .shop-by-pet__subheading {
	margin: 0 0 8px;
	color: var(--sbp-subheading-color);
}

#minion-section-{{ section.id }} .shop-by-pet__grid {
	position: relative;
	z-index: 2;
	display: grid;
	grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
	gap: var(--sbp-card-gap);
}

#minion-section-{{ section.id }} .shop-by-pet__card {
	position: relative;
	overflow: hidden;
	border-radius: var(--sbp-card-radius);
	min-height: var(--sbp-card-min-height);
	background: var(--sbp-card-bg, #f4f4f4);
	color: var(--sbp-card-text, var(--color-base));
}

#minion-section-{{ section.id }} .shop-by-pet__card-link {
	display: flex;
	align-items: stretch;
	justify-content: space-between;
	min-height: inherit;
	text-decoration: none;
	color: inherit;
}

#minion-section-{{ section.id }} .shop-by-pet__card-content {
	position: relative;
	z-index: 2;
	padding: var(--sbp-content-padding);
	width: calc(100% - var(--sbp-image-width));
	display: flex;
	flex-direction: column;
	gap: 14px;
}

#minion-section-{{ section.id }} .shop-by-pet__card-title {
	margin: 0;
	line-height: 1.2;
}

#minion-section-{{ section.id }} .shop-by-pet__card-arrow {
	width: 34px;
	height: 34px;
	border-radius: 50%;
	background: var(--sbp-arrow-bg, var(--color-accent));
	display: inline-flex;
	align-items: center;
	justify-content: center;
	color: var(--sbp-arrow-icon, #ffffff);
	flex: 0 0 auto;
}

#minion-section-{{ section.id }} .shop-by-pet__card-image-wrap {
	position: relative;
	width: var(--sbp-image-width);
	min-height: inherit;
}

#minion-section-{{ section.id }} .shop-by-pet__card-image-wrap img,
#minion-section-{{ section.id }} .shop-by-pet__card-image-wrap svg {
	position: absolute;
	right: 0;
	bottom: 0;
	width: 100%;
	height: 100%;
	object-fit: contain;
	object-position: bottom right;
}

#minion-section-{{ section.id }} .shop-by-pet__icon-layer {
	position: absolute;
	inset: 0;
	z-index: 1;
	pointer-events: none;
}

#minion-section-{{ section.id }} .shop-by-pet__icon {
	position: absolute;
	left: var(--sbp-left, 0%);
	top: var(--sbp-top, 0%);
	width: var(--sbp-size, 28px);
	opacity: calc(var(--sbp-icon-opacity) * var(--sbp-item-opacity, 1));
	transform: rotate(var(--sbp-rotate, 0deg));
}

#minion-section-{{ section.id }} .shop-by-pet__icon img {
	display: block;
	width: 100%;
	height: auto;
}

@media (max-width: 1024px) {
	#minion-section-{{ section.id }} .shop-by-pet__grid {
		grid-template-columns: repeat({{ section.settings.columns_tablet }}, minmax(0, 1fr));
	}
}

@media (max-width: 767px) {
	#minion-section-{{ section.id }} .shop-by-pet__surface {
		padding: 18px;
	}

	#minion-section-{{ section.id }} .shop-by-pet__subheading {
		font-size: 14px;
		line-height: 1.2;
	}

	#minion-section-{{ section.id }} .shop-by-pet__heading {
		font-size: 30px;
		font-weight: 700;
		line-height: 1.1;
	}

	#minion-section-{{ section.id }} .shop-by-pet__grid {
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
	}

	#minion-section-{{ section.id }} .shop-by-pet__card {
		min-height: 162px;
	}

	#minion-section-{{ section.id }} .shop-by-pet__card-content {
		width: 42%;
		padding: 10px;
		gap: 7px;
	}

	#minion-section-{{ section.id }} .shop-by-pet__card-image-wrap {
		width: 58%;
	}

	#minion-section-{{ section.id }} .shop-by-pet__card-title {
		font-size: 13px;
		line-height: 1.05;
	}

	#minion-section-{{ section.id }} .shop-by-pet__card-arrow {
		width: 20px;
		height: 20px;
	}

	#minion-section-{{ section.id }} .shop-by-pet__card-arrow svg {
		width: 8px;
		height: 8px;
	}

	#minion-section-{{ section.id }} .shop-by-pet__card-image-wrap img,
	#minion-section-{{ section.id }} .shop-by-pet__card-image-wrap svg {
		width: 132%;
		height: 132%;
		right: -14px;
		bottom: -6px;
	}
}
{%- endcapture -%}

<style>
	{{ section_styles }}
</style>

<div id="minion-section-{{ section.id }}" class="top-spacing-{{ section.settings.top_spacing }}" data-section-name="shop-by-pet">
	<div class="{{ page_width }}">
		<div class="shop-by-pet__surface mb--last-child-0">
			{%- if section.settings.subheading != blank or section.settings.heading != blank -%}
				<div class="shop-by-pet__header {{ section.settings.heading_alignment }}">
					{%- if section.settings.subheading != blank -%}
						<p class="shop-by-pet__subheading body3">{{ section.settings.subheading }}</p>
					{%- endif -%}
					{%- if section.settings.heading != blank -%}
						<h2 class="shop-by-pet__heading h2">{{ section.settings.heading }}</h2>
					{%- endif -%}
				</div>
			{%- endif -%}

			{%- if section.settings.show_background_icons -%}
				<div class="shop-by-pet__icon-layer" aria-hidden="true">
					{%- for block in section.blocks -%}
						{%- if block.type == 'bg_icon' and block.settings.icon_image != blank -%}
							<span
								class="shop-by-pet__icon"
								style="--sbp-left: {{ block.settings.position_x }}%; --sbp-top: {{ block.settings.position_y }}%; --sbp-size: {{ block.settings.icon_size }}px; --sbp-rotate: {{ block.settings.rotation }}deg; --sbp-item-opacity: {{ block.settings.icon_opacity | divided_by: 100.0 }};"
								{{ block.shopify_attributes }}
							>
								{{
									block.settings.icon_image
									| image_url: width: 220
									| image_tag:
										loading: 'lazy',
										widths: '64,96,128,160,220',
										sizes: '80px',
										alt: block.settings.alt_text
								}}
							</span>
						{%- endif -%}
					{%- endfor -%}
				</div>
			{%- endif -%}

			<div class="shop-by-pet__grid">
				{%- for block in section.blocks -%}
					{%- if block.type == 'pet_card' -%}
						<article
							class="shop-by-pet__card"
							style="--sbp-card-bg: {{ block.settings.card_bg }}; --sbp-card-text: {{ block.settings.text_color }}; --sbp-arrow-bg: {{ block.settings.arrow_bg }}; --sbp-arrow-icon: {{ block.settings.arrow_color }};"
							{{ block.shopify_attributes }}
						>
							{%- assign target_url = block.settings.link | default: '#' -%}
							<a class="shop-by-pet__card-link" href="{{ target_url }}"{% if block.settings.link == blank %} aria-disabled="true"{% endif %}>
								<div class="shop-by-pet__card-content">
									{%- if block.settings.title != blank -%}
										<h3 class="shop-by-pet__card-title h4">{{ block.settings.title | escape }}</h3>
									{%- endif -%}
									{%- if block.settings.show_arrow -%}
										<span class="shop-by-pet__card-arrow">
											<svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true" focusable="false">
												<path d="M3.5 7h7M7.5 3l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
											</svg>
										</span>
									{%- endif -%}
								</div>

								<div class="shop-by-pet__card-image-wrap">
									{%- if block.settings.image != blank -%}
										{{
											block.settings.image
											| image_url: width: 900
											| image_tag:
												loading: 'lazy',
												widths: '280,360,520,700,900',
												sizes: '(max-width: 767px) 45vw, 30vw',
												alt: block.settings.image.alt
										}}
									{%- else -%}
										{%- render 'icons-placeholder-other', icon_name: 'image-1' -%}
									{%- endif -%}
								</div>
							</a>
						</article>
					{%- endif -%}
				{%- endfor -%}
			</div>
		</div>
	</div>
</div>

{% schema %}
