        "default": "text-center",
        "label": "t:sections.general.settings.heading_aligment.label",
        "info": "t:sections.text-columns-with-images.settings.heading_aligment.info"
      },
      {
        "type": "header",
        "content": "t:sections.general.settings.header_layout.content"
      },
      {
        "type": "select",
        "id": "top_spacing",
